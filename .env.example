# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-supabase-anon-key
VITE_MAPBOX_TOKEN=pk.your-mapbox-token

# Backend (Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-host:5432/postgres
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password
SUPABASE_JWT_JWK_SET_URI=https://YOUR_PROJECT_ID.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER_URI=https://YOUR_PROJECT_ID.supabase.co/auth/v1
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
